<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category for custom roles -->
        <record id="module_category_rdl_roles" model="ir.module.category">
            <field name="name">RDL Custom Roles</field>
            <field name="sequence">100</field>
        </record>

        <!-- VSR Group -->
        <record id="group_vsr" model="res.groups">
            <field name="name">Van Sales Rep (VSR)</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
        </record>

        <!-- Store Cashier Group -->
        <record id="group_store_cashier" model="res.groups">
            <field name="name">Store Cashier</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
        </record>

        <!-- Manager Group -->
        <record id="group_manager" model="res.groups">
            <field name="name">Manager &amp; Inventory Admin</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_manager')), (4, ref('stock.group_stock_manager')), (4, ref('purchase.group_purchase_manager'))]"/>
        </record>

        <!-- Finance Custom Group -->
        <record id="group_finance_rdl" model="res.groups">
            <field name="name">Finance</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <!-- Inventory Manager Custom Group -->
        <record id="group_inventory_manager_rdl" model="res.groups">
            <field name="name">Inventory Manager</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_manager'))]"/>
        </record>

        <!-- Operations Manager Custom Group -->
        <record id="group_operations_manager_rdl" model="res.groups">
            <field name="name">Operations Manager</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_manager')), (4, ref('purchase.group_purchase_manager')), (4, ref('sales_team.group_sale_manager'))]"/>
        </record>

        <!-- Admin Custom Group -->
        <record id="group_admin_rdl" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="rdl_core_config.module_category_rdl_roles"/>
            <field name="implied_ids" eval="[(4, ref('base.group_system')), (4, ref('base.group_erp_manager'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Record Rules -->

        <!-- Restrict VSR to Van POS config -->
        <record id="rule_pos_config_vsr" model="ir.rule">
            <field name="name">VSR Allowed POS Configs</field>
            <field name="model_id" ref="point_of_sale.model_pos_config"/>
            <field name="groups" eval="[(4, ref('group_vsr'))]"/>
            <field name="domain_force">[('name', 'ilike', 'Van')]</field>
        </record>

        <!-- Restrict Store Cashier to Store POS config -->
        <record id="rule_pos_config_store_cashier" model="ir.rule">
            <field name="name">Store Cashier Allowed POS Configs</field>
            <field name="model_id" ref="point_of_sale.model_pos_config"/>
            <field name="groups" eval="[(4, ref('group_store_cashier'))]"/>
            <field name="domain_force">[('name', 'not ilike', 'Van')]</field>
        </record>

        <!-- Restrict VSR from central WH/Main location -->
        <record id="rule_vsr_exclude_central_stock" model="ir.rule">
            <field name="name">VSR Exclude Central Stock Location</field>
            <field name="model_id" ref="stock.model_stock_location"/>
            <field name="groups" eval="[(4, ref('group_vsr'))]"/>
            <field name="domain_force">[('complete_name', '!=', 'WH/Main')]</field>
        </record>

        <!-- Prevent VSR from seeing purchase orders -->
        <record id="rule_vsr_purchase_orders" model="ir.rule">
            <field name="name">VSR Exclude Purchase Orders</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="groups" eval="[(4, ref('group_vsr'))]"/>
            <field name="domain_force">[(0, '=', 1)]</field>
        </record>
    </data>
</odoo>
