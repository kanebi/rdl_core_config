<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_category_import_wizard_form" model="ir.ui.view">
        <field name="name">category.import.wizard.form</field>
        <field name="model">category.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Product Categories">
                <group>
                    <field name="file_name" invisible="1"/>
                    <field name="excel_file" filename="file_name"/>
                    <field name="sheet_index"/>
                    <field name="header_row_index"/>
                </group>
                <footer>
                    <button string="Import" name="action_import_categories" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_category_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Categories</field>
        <field name="res_model">category.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Inject Button into product.category tree view header -->
    <record id="product_category_list_view_inherit_rdl_import" model="ir.ui.view">
        <field name="name">product.category.list.inherit.rdl.import</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="%(action_category_import_wizard)d" string="Import Categories" type="action" class="btn-primary" display="always"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
