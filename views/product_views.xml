<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View Inheritance for Product Template -->
    <record id="product_template_search_view_inherit_rdl" model="ir.ui.view">
        <field name="name">product.template.search.inherit.rdl</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_sell']" position="before">
                <filter name="whole_products" string="Whole Products" domain="['|', ('is_brewery', '=', True), ('is_packaged_drinks', '=', True)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <!-- Search View Inheritance for Product Product -->
    <record id="product_search_form_view_inherit_rdl" model="ir.ui.view">
        <field name="name">product.product.search.inherit.rdl</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_sell']" position="before">
                <filter name="whole_products" string="Whole Products" domain="['|', ('is_brewery', '=', True), ('is_packaged_drinks', '=', True)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <!-- Custom List View for Whole Products Stock Report -->
    <record id="view_whole_products_stock_tree" model="ir.ui.view">
        <field name="name">product.product.whole.stock.list</field>
        <field name="model">product.product</field>
        <field name="priority" eval="200"/>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0" sample="1" duplicate="0">
                <field name="display_name" string="Product"/>
                <field name="categ_id" string="Category"/>
                <field name="qty_available" string="Quantity on Hand" sum="Total Quantity"/>
                <field name="standard_price" string="Unit Cost" widget="monetary"/>
                <field name="rdl_whole_valuation" string="Valuation" sum="Total Valuation" widget="monetary"/>
                <field name="uom_id" string="Unit" groups="uom.group_uom"/>
            </list>
        </field>
    </record>

    <!-- Action for Whole Products Stock Report -->
    <record id="action_whole_products_stock_report" model="ir.actions.act_window">
        <field name="name">Whole Products Stock Valuation</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_whole_products': 1, 'default_is_storable': True}</field>
        <field name="domain">[('is_storable', '=', True)]</field>
        <field name="view_id" ref="view_whole_products_stock_tree"/>
        <field name="search_view_id" ref="product.product_search_form_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No whole products stock to display
            </p>
        </field>
    </record>

    <!-- Menu Item under Inventory > Reporting -->
    <menuitem id="menu_whole_products_stock_report"
              name="Whole Products Stock Valuation"
              parent="stock.menu_warehouse_report"
              sequence="10"
              action="action_whole_products_stock_report"/>
</odoo>
